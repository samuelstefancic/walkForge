# SwiftFormat configuration — WalkForge

--swiftversion 6.2
--indent 4
--maxwidth 120
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--trimwhitespace always
--commas always
--semicolons never
--ifdef no-indent
--self remove
--importgrouping alpha

# Preserve explicit @Test("title") syntax (conflit avec identifier_name SwiftLint).
--disable swiftTestingTestCaseNames
--stripunusedargs closure-only
--header ignore

--exclude .build
--exclude .swiftpm
--exclude Build
--exclude DerivedData
